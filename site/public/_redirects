# Redirect *.pages.dev traffic to the custom domain
https://fluel-frontend.pages.dev/* https://fluel.io/:splat 301

# SPA fallback — serve index.html for any route that doesn't match a
# static asset. Solid Router then takes over on the client.
# Docs: https://developers.cloudflare.com/pages/configuration/redirects/
/*    /index.html   200
